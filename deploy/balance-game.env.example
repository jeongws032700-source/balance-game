# /etc/balance-game/balance-game.env 로 복사해서 채워 넣으세요.
# 비밀번호가 들어가므로 권한을 잠그세요:
#   sudo chown root:root /etc/balance-game/balance-game.env
#   sudo chmod 600       /etc/balance-game/balance-game.env

# === DB 접속 (application.properties 가 이 환경변수를 읽도록 분리해 둠) ===
DB_URL=jdbc:mariadb://localhost:3306/balancegame
DB_USERNAME=balance
DB_PASSWORD=여기에_강력한_비밀번호_입력

# === 서버 바인딩 ===
# cloudflared(같은 VM)만 접근하도록 루프백에만 바인딩 → 8080을 인터넷에 노출하지 않음
SERVER_ADDRESS=127.0.0.1
SERVER_PORT=8080
